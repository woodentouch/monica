# ============================================================
# Monica — Railway Environment Variables
# ============================================================
# Copy these into your Railway service's "Variables" tab.
# Do NOT commit real values to git.
# ============================================================

# --- Required ---

# Generate with: php artisan key:generate --show
# Or: echo -n 'base64:'; openssl rand -base64 32
APP_KEY=base64:REPLACE_ME

# Set AFTER first deploy once you have your Railway URL
APP_URL=https://your-app-name.up.railway.app

# Required for Railway's reverse proxy to generate correct HTTPS URLs
APP_TRUSTED_PROXIES=*

# --- Database (SQLite — cheapest option, no extra service) ---
# The SQLite file lives at storage/database.sqlite inside the container.
#
# *** IMPORTANT: add a Railway Volume mounted at /var/www/html/storage ***
# Without a volume, data is lost on every redeploy.
# Cost: ~$0.25/GB-month — a few MB costs essentially nothing.
#
DB_CONNECTION=sqlite

# --- Alternatively: use Railway PostgreSQL plugin ---
# Add a Postgres plugin in Railway dashboard, then set:
# DB_CONNECTION=pgsql
# DB_HOST=${{Postgres.PGHOST}}
# DB_PORT=${{Postgres.PGPORT}}
# DB_DATABASE=${{Postgres.PGDATABASE}}
# DB_USERNAME=${{Postgres.PGUSER}}
# DB_PASSWORD=${{Postgres.PGPASSWORD}}

# --- App settings ---
APP_NAME=Monica
APP_ENV=production
APP_DEBUG=false
APP_DISABLE_SIGNUP=false

# --- Drivers (no Redis/Memcached needed — saves cost) ---
CACHE_STORE=database
QUEUE_CONNECTION=sync
SESSION_DRIVER=database

# --- Search (no Meilisearch needed — saves cost) ---
SCOUT_DRIVER=database
SCOUT_QUEUE=false

# --- Logging ---
LOG_CHANNEL=stderr

# --- Email (optional) ---
# Default: emails are written to logs (no real sending).
# To send real emails, set MAIL_MAILER=smtp and fill in the rest.
MAIL_MAILER=log
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=monica@example.com
# MAIL_FROM_NAME=Monica
